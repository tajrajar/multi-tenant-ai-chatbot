APP_NAME=SecureAIBackend

ENVIRONMENT=development

# Comma-separated origins (recommended) or JSON array — both work.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173

# TICKET-002 NOTE:
# This is a placeholder. It will be replaced with a real Supabase
# Postgres connection string, e.g.:
# postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/secure_ai_db

# Generate a real one using: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_a_secure_random_value



# Supabase project credentials (Ticket-002)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here